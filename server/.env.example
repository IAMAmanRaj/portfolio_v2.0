# Database URLs
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT].supabase.co:6543/postgres?pgbouncer=true"

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET="your-secret-key"
CLIENT_ORIGIN="http://localhost:5173"
JWT_EXPIRES_IN="1d"
AUTH_COOKIE_NAME="auth_token"
CSRF_COOKIE_NAME="csrf_token"

# Prisma seed (run from server/: `npx prisma db seed`)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin_password"
# Optional display name for the seeded admin
# SEED_ADMIN_DISPLAY_NAME="Admin"
# Author seed users use the same password unless you set this
# SEED_AUTHOR_PASSWORD="change-me-at-least-6-chars"
